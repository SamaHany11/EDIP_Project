# SQL Server
DB_URL=jdbc:sqlserver://your-server:1433;databaseName=your-db;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# MongoDB Atlas
MONGO_URI=mongodb+srv://your_mongo_username:your_mongo_password@cluster.mongodb.net/?appName=YOUR_APP

# Mail
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_mail_password

# JWT
JWT_SECRET=your_jwt_secret

# Frontend
FRONTEND_URL=https://your-frontend-url.com

# AI API
AI_API_URL=https://your-ai-api-url.com/api/v1/process
RAG_BASE_URL=https://your-rag-base-url.com
AI_API_KEY=your_ai_api_key
RAG_GROQ_KEY=your_rag_groq_key

# Brevo Mail Key
BREVO_API_KEY=your_brevo_api_key